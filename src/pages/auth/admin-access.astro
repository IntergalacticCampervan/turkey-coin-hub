---
export const prerender = false;

const url = new URL(Astro.request.url);
const usersReady = url.searchParams.get('users') === '1';
const adminReady = url.searchParams.get('admin') === '1';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0c0f" />
    <link rel="icon" type="image/svg+xml" href="/Turkeycoin.svg" />
    <title>Admin Access | Turkey Coin Hub</title>
    <style>
      :root {
        --phosphor-primary: #ff7a00;
        --phosphor-accent: #00e0c6;
        --line: rgba(255, 145, 38, 0.45);
        --line-soft: rgba(255, 145, 38, 0.28);
        --bg-core: #0f131a;
        --bg-panel: rgba(16, 20, 28, 0.92);
        --text-muted: rgba(255, 158, 56, 0.72);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100dvh;
        padding: 1rem;
        color: var(--phosphor-primary);
        font-family: 'Share Tech Mono', 'Courier Prime', 'Courier New', monospace;
        background:
          radial-gradient(circle at top right, rgba(255, 122, 0, 0.12), transparent 42%),
          radial-gradient(circle at top left, rgba(0, 224, 198, 0.08), transparent 36%),
          var(--bg-core);
      }

      main {
        width: min(100%, 920px);
        margin: 0 auto;
        border: 1px solid var(--line);
        background: var(--bg-panel);
        padding: clamp(1rem, 2.4vw, 1.5rem);
        display: grid;
        gap: 1rem;
      }

      h1,
      h2,
      p {
        margin: 0;
      }

      h1 {
        font-size: clamp(1.5rem, 3vw, 2.15rem);
      }

      p {
        color: var(--text-muted);
        line-height: 1.5;
      }

      .actions,
      .steps {
        display: grid;
        gap: 0.75rem;
      }

      .step {
        border: 1px solid var(--line-soft);
        padding: 0.9rem;
        display: grid;
        gap: 0.55rem;
      }

      .step-head {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        align-items: center;
      }

      .status {
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .status.ready {
        color: var(--phosphor-accent);
      }

      .status.pending {
        color: var(--phosphor-primary);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
      }

      .button {
        border: 1px solid var(--phosphor-accent);
        color: #001916;
        background: var(--phosphor-accent);
        text-decoration: none;
        padding: 0.7rem 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.86rem;
      }

      .button.secondary {
        border-color: var(--line);
        color: var(--phosphor-primary);
        background: rgba(255, 122, 0, 0.08);
      }

      .note {
        border: 1px solid var(--line-soft);
        padding: 0.9rem;
      }
    </style>
  </head>
  <body>
    <main>
      <div>
        <h1>ADMIN ACCESS HANDSHAKE</h1>
        <p>
          Your Cloudflare Access setup uses separate protected applications for the admin UI and the admin APIs.
          Complete both API checks below, then return to the admin panel.
        </p>
      </div>

      <div class="steps">
        <section class="step">
          <div class="step-head">
            <h2>1. Authorize Users API</h2>
            <span class={`status ${usersReady ? 'ready' : 'pending'}`}>{usersReady ? 'complete' : 'pending'}</span>
          </div>
          <p>Authenticates requests to <code>/api/users*</code>, which the admin panel needs to load the user list.</p>
          <div class="button-row">
            <a class="button" href={`/api/users/auth?${url.searchParams.toString()}`}>Authorize Users API</a>
          </div>
        </section>

        <section class="step">
          <div class="step-head">
            <h2>2. Authorize Admin API</h2>
            <span class={`status ${adminReady ? 'ready' : 'pending'}`}>{adminReady ? 'complete' : 'pending'}</span>
          </div>
          <p>Authenticates requests to <code>/api/admin/*</code>, which the admin panel needs for mint events and actions.</p>
          <div class="button-row">
            <a class="button" href={`/api/admin/auth?${url.searchParams.toString()}`}>Authorize Admin API</a>
          </div>
        </section>
      </div>

      <section class="note">
        <p>
          After both checks complete, return to the admin screen. If your Access policies share session state, one or
          both checks may complete without another prompt.
        </p>
      </section>

      <div class="button-row">
        <a class="button secondary" href="/admin">Return to Admin</a>
        <a class="button secondary" href="/">Return to Dashboard</a>
      </div>
    </main>
  </body>
</html>
